---
import ContactLinks from "../../components/ContactLinks.astro";
import Education from "../../components/Education.astro";
import Experience from "../../components/Experience.astro";
import Hero from "../../components/Hero.astro";
import Projects from "../../components/Projects.astro";
import Summary from "../../components/Summary.astro";
import {
  defaultLocale,
  isLocale,
  locales,
  siteContentByLocale,
} from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { lang: locale } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : defaultLocale;
const siteContent = siteContentByLocale[lang];
---

<BaseLayout
  title={siteContent.meta.title}
  description={siteContent.meta.description}
  lang={siteContent.locale}
  skipLink={siteContent.skipLink}
  navItems={siteContent.nav}
  languageSwitcher={siteContent.languageSwitcher}
  header={siteContent.header}
>
  <main id="main-content">
    <Hero hero={siteContent.hero} links={siteContent.contacts} />
    <Summary summary={siteContent.summary} />
    <Experience
      experience={siteContent.experience}
      section={siteContent.experienceSection}
    />
    <Projects
      projects={siteContent.projects}
      section={siteContent.projectsSection}
    />
    <Education
      education={siteContent.education}
      section={siteContent.educationSection}
    />
    <ContactLinks
      links={siteContent.contacts}
      section={siteContent.contactSection}
    />
  </main>
</BaseLayout>
