---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
const { experience, section } = Astro.props;
const [primaryExperience, ...secondaryExperience] = experience;
---

<section
  id="experience"
  class="scroll-mt-32 px-6 py-12 lg:px-8"
  aria-labelledby="experience-title"
>
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      <p
        class="text-xs font-extrabold tracking-[0.32em] text-teal-300 uppercase"
      >
        {section.eyebrow}
      </p>
      <h2
        id="experience-title"
        class="mt-4 text-3xl font-extrabold text-white sm:text-4xl"
      >
        {section.title}
      </h2>
    </div>

    <div
      class="mt-8 grid gap-6 md:grid-cols-[1fr_20rem] lg:grid-cols-[1fr_24rem]"
    >
      {
        primaryExperience && (
          <article class="rounded-3xl border border-[#5EEAD4] bg-[linear-gradient(135deg,#0F766E_0%,#0B1B2A_100%)] p-8 shadow-2xl shadow-teal-950/25">
            <p class="text-sm font-bold text-teal-100">
              {primaryExperience.period}
            </p>
            <h3 class="mt-3 text-2xl font-extrabold text-white">
              {primaryExperience.company} · {primaryExperience.role}
            </h3>
            <p class="mt-4 text-base leading-7 text-[#D1FAE5]">
              {primaryExperience.description}
            </p>
            <ul class="mt-6 space-y-3 text-base leading-7 text-[#D1FAE5]">
              {primaryExperience.highlights.map((highlight) => (
                <li class="flex gap-3">
                  <span
                    class="mt-3 h-1.5 w-1.5 rounded-full bg-teal-300"
                    aria-hidden="true"
                  />
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
          </article>
        )
      }

      <div class="grid gap-6">
        {
          secondaryExperience.map((item) => (
            <article class="rounded-3xl border border-[#164E63] bg-[#0B1B2A] p-7">
              <p class="text-sm font-bold text-cyan-200">{item.period}</p>
              <h3 class="mt-3 text-xl font-extrabold text-white">
                {item.company} · {item.role}
              </h3>
              <p class="mt-4 text-sm leading-6 text-[#B6E7E1]">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
