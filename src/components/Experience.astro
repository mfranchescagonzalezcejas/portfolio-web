---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
const { experience } = Astro.props;
const [primaryExperience, ...secondaryExperience] = experience;
---

<section
  class="mx-auto max-w-6xl px-6 py-12 lg:px-8"
  aria-labelledby="experience-title"
>
  <div class="max-w-3xl">
    <p class="text-xs font-extrabold tracking-[0.32em] text-teal-300 uppercase">
      Experience
    </p>
    <h2
      id="experience-title"
      class="mt-4 text-3xl font-extrabold text-white sm:text-4xl"
    >
      Production context, not just side projects.
    </h2>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_24rem]">
    {
      primaryExperience && (
        <article class="rounded-3xl border border-teal-300/40 bg-[linear-gradient(135deg,rgba(15,118,110,0.55),rgba(15,23,42,0.92))] p-8 shadow-2xl shadow-teal-950/25">
          <p class="text-sm font-bold text-teal-100">
            {primaryExperience.period}
          </p>
          <h3 class="mt-3 text-2xl font-extrabold text-white">
            {primaryExperience.company} · {primaryExperience.role}
          </h3>
          <p class="mt-4 text-base leading-7 text-teal-50/80">
            {primaryExperience.description}
          </p>
          <ul class="mt-6 space-y-3 text-base leading-7 text-teal-50/85">
            {primaryExperience.highlights.map((highlight) => (
              <li class="flex gap-3">
                <span
                  class="mt-3 h-1.5 w-1.5 rounded-full bg-teal-300"
                  aria-hidden="true"
                />
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
        </article>
      )
    }

    <div class="grid gap-6">
      {
        secondaryExperience.map((item) => (
          <article class="rounded-3xl border border-cyan-700/45 bg-slate-900/70 p-7">
            <p class="text-sm font-bold text-cyan-200">{item.period}</p>
            <h3 class="mt-3 text-xl font-extrabold text-white">
              {item.company} · {item.role}
            </h3>
            <p class="mt-4 text-sm leading-6 text-cyan-50/75">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
