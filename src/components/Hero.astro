---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
const { hero, links } = Astro.props;

const linkStyles = [
  "bg-[#14B8A6] text-[#042F2E] hover:bg-teal-300",
  "border border-[#38BDF8] bg-[#082F49] text-[#BAE6FD] hover:bg-sky-900",
  "border border-[#2DD4BF] bg-[#0F172A] text-[#CCFBF1] hover:bg-slate-800",
];

const skillChips = [
  "bg-[#0F766E] text-white",
  "bg-[#075985] text-white",
  "bg-[#115E59] text-white",
  "bg-[#1E3A8A] text-white",
  "bg-[#0E7490] text-white",
];
---

<section class="px-6 pt-8 pb-12 sm:pt-12 lg:px-8" aria-labelledby="hero-title">
  <div
    class="mx-auto max-w-6xl rounded-[2rem] border border-[#155E75] bg-[linear-gradient(135deg,#0F2A3A_0%,#06111F_54%,#042F2E_100%)] p-6 shadow-2xl shadow-cyan-950/30 sm:p-10 md:grid md:grid-cols-[1fr_20rem] md:gap-10 lg:grid-cols-[1fr_24rem] lg:gap-12 lg:p-16"
  >
    <div>
      <p class="mb-3 text-sm font-extrabold text-teal-100">
        {hero.shortName}
      </p>
      <p
        class="mb-5 text-xs font-extrabold tracking-[0.32em] text-teal-300 uppercase"
      >
        {hero.eyebrow}
      </p>
      <h1
        id="hero-title"
        class="text-4xl leading-tight font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl"
      >
        {hero.name}
      </h1>
      <p
        class="mt-6 max-w-3xl text-xl leading-8 font-semibold text-[#C8F7F0] lg:text-2xl lg:leading-9"
      >
        {hero.tagline}
      </p>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-[#C8F7F0]/85">
        {hero.summary}
      </p>
      <ul class="mt-8 flex flex-wrap gap-3" aria-label="Primary profile links">
        {
          links.map((link, index) => (
            <li>
              <a
                class:list={[
                  "inline-flex rounded-full px-5 py-3 text-sm font-extrabold transition focus-visible:outline-teal-300",
                  linkStyles[index] ?? linkStyles[1],
                ]}
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <aside
      class="mt-10 rounded-3xl border border-[#164E63] bg-[#071827] p-6 md:mt-0 lg:p-7"
      aria-label="Professional focus"
    >
      <p
        class="text-xs font-extrabold tracking-[0.28em] text-cyan-300 uppercase"
      >
        {hero.panelLabel}
      </p>
      <h2
        class="mt-4 text-xl leading-7 font-extrabold text-white lg:text-2xl lg:leading-8"
      >
        {hero.panelTitle}
      </h2>
      <p class="mt-4 text-base leading-7 text-[#A7F3D0]">
        {hero.panelText}
      </p>
      <div class="mt-6 flex flex-wrap gap-2">
        {
          hero.skills.map((skill, index) => (
            <span
              class:list={[
                "rounded-full px-3 py-1 text-xs font-bold",
                skillChips[index] ?? skillChips[0],
              ]}
            >
              {skill}
            </span>
          ))
        }
      </div>
    </aside>
  </div>
</section>
