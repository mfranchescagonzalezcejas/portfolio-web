---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
import ProjectCard from "./ProjectCard.astro";

const { projects } = Astro.props;
const featuredProject = projects.find((project) => project.featured);
const otherProjects = projects.filter((project) => project !== featuredProject);
---

<section
  class="mx-auto max-w-6xl px-6 py-12 lg:px-8"
  aria-labelledby="projects-title"
>
  <div class="max-w-3xl">
    <p class="text-xs font-extrabold tracking-[0.32em] text-teal-300 uppercase">
      Projects
    </p>
    <h2
      id="projects-title"
      class="mt-4 text-3xl font-extrabold text-white sm:text-4xl"
    >
      Selected proof of work.
    </h2>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_24rem]">
    {featuredProject && <ProjectCard project={featuredProject} featured />}
    <div class="grid gap-6">
      {otherProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
