---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
const { project } = Astro.props;
---

<article
  class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/20"
>
  <div class="flex flex-wrap items-center gap-3">
    <h3 class="text-xl font-bold text-white">{project.name}</h3>
    {
      project.featured && (
        <span class="rounded-full bg-sky-300/15 px-3 py-1 text-xs font-semibold text-sky-200">
          Featured
        </span>
      )
    }
  </div>
  <p class="mt-4 text-base leading-7 text-slate-300">
    {project.description}
  </p>
  {
    project.links.length > 0 && (
      <ul
        class="mt-6 flex flex-wrap gap-3"
        aria-label={`${project.name} links`}
      >
        {project.links.map((link) => (
          <li>
            <a
              class="inline-flex rounded-full border border-sky-300/40 px-4 py-2 text-sm font-semibold text-sky-200 transition hover:border-sky-200 hover:text-sky-100"
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</article>
