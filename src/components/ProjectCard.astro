---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
const { project, featured = false } = Astro.props;
---

<article
  class:list={[
    "rounded-3xl border p-6 shadow-xl shadow-slate-950/20",
    featured
      ? "border-cyan-300/40 bg-cyan-950/55 sm:p-8"
      : "border-teal-800/50 bg-slate-900/70",
  ]}
>
  <div class="flex flex-wrap items-center gap-3">
    <h3
      class:list={[
        "font-extrabold text-white",
        featured ? "text-3xl" : "text-xl",
      ]}
    >
      {project.name}
    </h3>
    {
      project.featured && (
        <span class="rounded-full bg-teal-300/15 px-3 py-1 text-xs font-extrabold tracking-wide text-teal-100 ring-1 ring-teal-300/25">
          Featured
        </span>
      )
    }
  </div>
  <p
    class:list={[
      "mt-4 leading-7",
      featured ? "text-base text-cyan-50/80" : "text-sm text-teal-50/70",
    ]}
  >
    {project.description}
  </p>
  {
    project.links.length > 0 && (
      <ul
        class="mt-6 flex flex-wrap gap-3"
        aria-label={`${project.name} links`}
      >
        {project.links.map((link) => (
          <li>
            <a
              class="inline-flex rounded-full border border-cyan-300/40 px-4 py-2 text-sm font-bold text-cyan-100 transition hover:border-cyan-200 hover:bg-cyan-300/10 hover:text-white"
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</article>
