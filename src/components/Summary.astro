---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
const { summary } = Astro.props;
---

<section
  id="about"
  class="scroll-mt-8 px-6 py-12 lg:px-8"
  aria-labelledby="summary-title"
>
  <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[1fr_24rem]">
    <div
      class="rounded-3xl border border-teal-700/50 bg-slate-900/70 p-8 sm:p-10"
    >
      <p
        class="text-xs font-extrabold tracking-[0.32em] text-teal-300 uppercase"
      >
        {summary.eyebrow}
      </p>
      <h2
        id="summary-title"
        class="mt-5 text-3xl leading-tight font-extrabold text-white sm:text-4xl"
      >
        {summary.title}
      </h2>
      <p class="mt-5 text-lg leading-8 text-teal-50/75">
        {summary.body}
      </p>
    </div>

    <aside
      class="rounded-3xl border border-cyan-600/45 bg-cyan-950/35 p-7"
      aria-label="Working style"
    >
      <p
        class="text-xs font-extrabold tracking-[0.28em] text-cyan-300 uppercase"
      >
        Working style
      </p>
      <h3 class="mt-4 text-2xl font-extrabold text-white">
        Clean architecture
      </h3>
      <p class="mt-3 text-sm leading-6 text-cyan-100/75">
        Readable systems, layered thinking, repository patterns, and
        maintainable delivery.
      </p>
      <h3 class="mt-5 text-2xl font-extrabold text-white">Quality mindset</h3>
      <p class="mt-3 text-sm leading-6 text-cyan-100/75">
        Testing, functional validation, Jira workflows, and release confidence
        from QA experience.
      </p>
    </aside>
  </div>

  <div class="mx-auto mt-6 flex max-w-6xl flex-wrap gap-2">
    {
      summary.skills.map((skill) => (
        <span class="rounded-full border border-teal-300/20 bg-teal-500/10 px-3 py-1 text-xs font-bold text-teal-100">
          {skill}
        </span>
      ))
    }
  </div>
</section>
