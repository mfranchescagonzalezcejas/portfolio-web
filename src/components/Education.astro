---
// @ts-nocheck -- ESLint baseline cannot parse typed Astro frontmatter yet.
const { education } = Astro.props;

const cardStyles = [
  "border-[#0E7490] bg-[#062A30]",
  "border-[#38BDF8] bg-[#082F49]",
  "border-[#164E63] bg-[#0B1B2A]",
];
---

<section
  id="education"
  class="scroll-mt-32 px-6 py-12 lg:px-8"
  aria-labelledby="education-title"
>
  <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[1fr_32rem]">
    <div class="rounded-3xl border border-[#134E4A] bg-[#0B1B2A] p-8">
      <p
        class="text-xs font-extrabold tracking-[0.32em] text-teal-300 uppercase"
      >
        Education
      </p>
      <h2 id="education-title" class="mt-4 text-3xl font-extrabold text-white">
        Engineering foundation with ongoing AI development training.
      </h2>
    </div>

    <div class="grid gap-4">
      {
        education.map((item, index) => (
          <article
            class:list={[
              "rounded-3xl border p-6",
              cardStyles[index] ?? cardStyles[0],
            ]}
          >
            <h3 class="text-lg font-extrabold text-[#ECFEFF]">{item.title}</h3>
            <p class="mt-2 text-sm font-semibold text-[#BAE6FD]">{item.meta}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
